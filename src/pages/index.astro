---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getSortedArticles } from '../utils/articles';

const articles = await getSortedArticles();

const grouped = Map.groupBy(articles, (a) => a.data.date.getFullYear());

function formatDate(date: Date) {
	return date.toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' });
}
---

<Layout title="Essays — Pedram's Blog" description="Essays on engineering leadership, decision-making, and the craft of building software by Pedram Taheri.">
	<Header activeNav="essays" />

	<main class="pt-28 md:pt-32 pb-24 px-6 max-w-4xl mx-auto min-h-screen">
		<h1 class="mb-16 md:mb-24 font-headline font-semibold text-5xl md:text-6xl tracking-tight text-on-surface leading-none">
			Essays
		</h1>

		<div class="space-y-16">
			{[...grouped.entries()].map(([year, items], i) => (
				<>
					{i > 0 && <hr class="border-0 h-px w-12 bg-outline-variant/30" />}
					<div class="flex flex-col space-y-12">
						{items.map((article) => (
							<article class="group">
								<a href={`/articles/${article.id}`} class="flex flex-col md:flex-row md:items-baseline gap-2 md:gap-12">
									<span class="font-label text-outline text-xs tracking-widest uppercase md:w-24 shrink-0 transition-colors group-hover:text-primary-fixed-dim">
										{formatDate(article.data.date)}
									</span>
									<h2 class="font-headline text-2xl md:text-3xl text-on-surface-variant transition-all duration-300 group-hover:text-on-surface group-hover:translate-x-1" transition:name={`article-title-${article.id}`}>
										{article.data.title}
									</h2>
								</a>
							</article>
						))}
					</div>
				</>
			))}
		</div>

		<p class="mt-24 md:mt-32 text-center font-label text-2xs tracking-[0.5em] text-outline-variant uppercase">
			End of Index
		</p>
	</main>

	<Footer />
</Layout>
