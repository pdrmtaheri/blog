---
import { render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getArticleStaticPaths } from '../../utils/articles';

export const getStaticPaths = getArticleStaticPaths;

const { article } = Astro.props;
const { Content } = await render(article);
const { title, date, tags, description } = article.data;

const formattedDate = date.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<Layout
	title={`${title} — Pedram's Blog`}
	description={description}
	ogImage={`/og/${article.id}.png`}
	article={{ publishedTime: date.toISOString(), tags }}
>
	<Header activeNav="essays" compact progressBar />

	<main class="pt-28 md:pt-32 pb-24 px-6 max-w-3xl mx-auto">
		<header class="mb-16">
			<div id="compact-sentinel" class="flex gap-3 mb-4">
				{tags.map((tag) => (
					<span class="font-label text-accent text-xs uppercase tracking-[0.2em]">{tag}</span>
				))}
			</div>
			<h1 class="text-4xl md:text-6xl font-headline font-semibold text-on-surface leading-[1.1] tracking-tight mb-8" transition:name={`article-title-${article.id}`}>
				{title}
			</h1>
			<time datetime={date.toISOString()} class="font-label text-xs text-outline uppercase tracking-widest">
				{formattedDate}
			</time>
		</header>

		<blockquote class="text-xl md:text-2xl text-on-surface-variant leading-relaxed font-headline italic mb-16 border-l-2 border-accent pl-8">
			{description}
		</blockquote>

		<article class="prose">
			<Content />
		</article>

		<div class="mt-24 flex flex-col items-center gap-6">
			<hr class="border-0 w-12 h-px bg-accent" />
			<span class="font-label text-2xs uppercase tracking-[0.4em] text-outline">Share</span>
			<div class="flex gap-6">
				<a id="share-x" href="#" target="_blank" rel="noopener noreferrer" class="text-outline hover:text-on-surface transition-colors cursor-pointer" title="Share on X">
					<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
				</a>
				<a id="share-linkedin" href="#" target="_blank" rel="noopener noreferrer" class="text-outline hover:text-on-surface transition-colors cursor-pointer" title="Share on LinkedIn">
					<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
				</a>
				<a id="share-hn" href="#" target="_blank" rel="noopener noreferrer" class="text-outline hover:text-on-surface transition-colors cursor-pointer" title="Share on Hacker News">
					<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M0 0v24h24V0H0zm12.8 13.4v5.2h-1.6v-5.2L7.3 5.6h1.8l3 5.4 2.9-5.4h1.8l-4 7.8z"/></svg>
				</a>
				<button id="share-copy" class="text-outline hover:text-on-surface transition-colors cursor-pointer" title="Copy link">
					<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
				</button>
			</div>
		</div>

		<div id="copy-toast" class="fixed bottom-8 left-1/2 -translate-x-1/2 bg-on-surface text-surface font-label text-xs uppercase tracking-widest px-6 py-3 opacity-0 transition-opacity duration-300 pointer-events-none z-50">
			Link copied
		</div>
	</main>

	<Footer />
</Layout>

<script>
	let articleController: AbortController | null = null;

	function setupArticlePage() {
		articleController?.abort();
		articleController = new AbortController();
		const { signal } = articleController;

		const bar = document.getElementById('reading-progress');
		if (bar) {
			window.addEventListener('scroll', () => {
				const scrollTop = window.scrollY;
				const docHeight = document.documentElement.scrollHeight - window.innerHeight;
				const progress = docHeight > 0 ? Math.min((scrollTop / docHeight) * 100, 100) : 0;
				bar.style.width = `${progress}%`;
			}, { passive: true, signal });
		}

		const url = encodeURIComponent(window.location.href);
		const title = encodeURIComponent(document.title);

		document.getElementById('share-x')?.setAttribute('href', `https://x.com/intent/tweet?url=${url}&text=${title}`);
		document.getElementById('share-linkedin')?.setAttribute('href', `https://www.linkedin.com/sharing/share-offsite/?url=${url}`);
		document.getElementById('share-hn')?.setAttribute('href', `https://news.ycombinator.com/submitlink?u=${url}&t=${title}`);

		document.getElementById('share-copy')?.addEventListener('click', async () => {
			await navigator.clipboard.writeText(window.location.href);
			const toast = document.getElementById('copy-toast');
			if (toast) {
				toast.style.opacity = '1';
				setTimeout(() => { toast.style.opacity = '0'; }, 2000);
			}
		}, { signal });
	}

	document.addEventListener('astro:page-load', setupArticlePage);
</script>
