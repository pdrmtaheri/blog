---
import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';
import { SITE } from '../config';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	article?: {
		publishedTime: string;
		tags: string[];
	};
	extraJsonLd?: Record<string, unknown>[];
}

const {
	title = SITE.title,
	description = SITE.description,
	ogImage = '/og-default.png',
	article,
	extraJsonLd,
} = Astro.props;

const siteUrl = Astro.site!.origin;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);

const jsonLd: Record<string, unknown>[] = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		'@id': `${siteUrl}/#website`,
		name: SITE.title,
		url: siteUrl,
		description: SITE.description,
		author: { '@id': `${siteUrl}/#author` },
		inLanguage: 'en',
	},
];

if (extraJsonLd) jsonLd.push(...extraJsonLd);

if (article) {
	const headline = title.replace(` — ${SITE.title}`, '');
	jsonLd.push(
		{
			'@context': 'https://schema.org',
			'@type': 'BlogPosting',
			'@id': canonicalUrl.href,
			headline,
			description,
			datePublished: article.publishedTime,
			dateModified: article.publishedTime,
			author: {
				'@type': 'Person',
				'@id': `${siteUrl}/#author`,
				name: SITE.author,
				url: `${siteUrl}/about`,
				jobTitle: SITE.authorMeta.jobTitle,
				worksFor: { '@type': 'Organization', name: SITE.authorMeta.worksFor },
			},
			publisher: {
				'@type': 'Person',
				'@id': `${siteUrl}/#author`,
				name: SITE.author,
			},
			image: ogImageUrl.href,
			keywords: article.tags,
			inLanguage: 'en',
			isPartOf: { '@id': `${siteUrl}/#website` },
			mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl.href },
		},
		{
			'@context': 'https://schema.org',
			'@type': 'BreadcrumbList',
			itemListElement: [
				{ '@type': 'ListItem', position: 1, name: 'Essays', item: siteUrl },
				{ '@type': 'ListItem', position: 2, name: headline, item: canonicalUrl.href },
			],
		},
	);
}
---

<!doctype html>
<html lang="en">
	<head>
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-BNX2YYWHV5"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-BNX2YYWHV5');
		</script>

		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="manifest" href="/site.webmanifest" />

		<Font cssVariable="--font-newsreader" />
		<Font cssVariable="--font-jetbrains-mono" />

		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="author" content={SITE.author} />
		<meta name="theme-color" content="#fcfaf9" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#131313" media="(prefers-color-scheme: dark)" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />

		<meta property="og:type" content={article ? 'article' : 'website'} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:site_name" content={SITE.title} />
		{article && <meta property="article:published_time" content={article.publishedTime} />}
		{article?.tags.map((tag) => <meta property="article:tag" content={tag} />)}

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

		<title>{title}</title>
		<ClientRouter />
	</head>
	<body>
		<slot />
	</body>
</html>

<!-- Compact header: gradually shrinks nav padding on scroll.
     Requires id="compact-sentinel" (articles/[...slug].astro) and class="site-header" (Header compact prop). -->
<script>
	let controller: AbortController | null = null;

	function setup() {
		controller?.abort();
		controller = new AbortController();
		const { signal } = controller;

		const sentinel = document.getElementById('compact-sentinel');
		const header = document.querySelector('.site-header');
		if (!header || !sentinel) return;
		const nav = header.querySelector('nav');
		if (!nav) return;

		const isMobile = window.matchMedia('(max-width: 767px)').matches;
		const maxPad = isMobile ? 24 : 32;
		const minPad = 8;
		const range = maxPad - minPad;
		const transitionDistance = range * 3;

		window.addEventListener('scroll', () => {
			const progress = Math.min(Math.max(window.scrollY / transitionDistance, 0), 1);
			const pad = `${maxPad - range * progress}px`;
			nav.style.paddingTop = pad;
			nav.style.paddingBottom = pad;
		}, { passive: true, signal });
	}

	setup();
	document.addEventListener('astro:after-swap', setup);
</script>
