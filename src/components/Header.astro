---
interface Props {
	activeNav: 'essays' | 'about';
	compact?: boolean;
	progressBar?: boolean;
}

const { activeNav, compact = false, progressBar = false } = Astro.props;

const navBase = 'font-label uppercase text-xs tracking-widest border-b-2 pb-1 transition-colors duration-200';
const activeClass = 'text-accent font-bold border-accent';
const inactiveClass = 'text-outline border-transparent hover:text-on-surface';
---

<header class:list={['fixed top-0 w-full z-50 bg-surface', { 'site-header': compact }]}>
	{progressBar && (
		<div id="reading-progress" class="absolute bottom-0 left-0 h-0.5 bg-accent" style="width: 0%"></div>
	)}
	<nav class="max-w-4xl mx-auto flex justify-between items-center py-6 md:py-8 px-6">
		<a href="/" class="font-headline font-semibold text-xl tracking-tighter text-on-surface">
			Pedram's Blog
		</a>
		<div class="flex items-center gap-8">
			<a href="/" class:list={[navBase, activeNav === 'essays' ? activeClass : inactiveClass]}>
				Essays
			</a>
			<a href="/about" class:list={[navBase, activeNav === 'about' ? activeClass : inactiveClass]}>
				About
			</a>
			<button
				id="theme-toggle"
				class="text-primary hover:text-on-surface transition-colors duration-200"
				aria-label="Toggle theme"
			>
				<svg id="icon-dark" class="w-5 h-5 hidden" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 0 1-4.4 2.26 5.403 5.403 0 0 1-3.14-9.8c-.44-.06-.9-.1-1.36-.1z"/></svg>
				<svg id="icon-light" class="w-5 h-5 hidden" viewBox="0 0 24 24" fill="currentColor"><path d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58a.996.996 0 0 0-1.41 0 .996.996 0 0 0 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37a.996.996 0 0 0-1.41 0 .996.996 0 0 0 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0a.996.996 0 0 0 0-1.41l-1.06-1.06zm1.06-10.96a.996.996 0 0 0 0-1.41.996.996 0 0 0-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06zM7.05 18.36a.996.996 0 0 0 0-1.41.996.996 0 0 0-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06z"/></svg>
			</button>
		</div>
	</nav>
</header>
